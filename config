# Bot de Señales - Análisis de Mercado Real (Bitget)
# Este bot NO ejecuta operaciones, solo envía alertas
estrategia:
  ema_lenta: 21
  ema_rapida: 8
  ema_tendencia: 200
  adx_periodo: 14
  adx_umbral: 15  # Umbral reducido para más señales
  volumen_ma: 20
  rsi_periodo: 14
  temporalidad_diaria: D
  temporalidad_ejecucion: '5'

analisis:
  escaneo_intervalo: 60  # Segundos entre escaneos completos
  max_señales_por_hora: 10  # Limitar spam de señales
  
riesgo:
  stop_loss_atr_multiplicador: 2.0
  take_profit_ratio: 3.0  # Sugerencia de ratio R:R para señales
  apalancamiento_sugerido: 5
